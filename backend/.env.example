# Application
APP_NAME=Hack2Hire API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (async runtime URL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hack2hire

# Database (sync URL for Alembic migrations)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/hack2hire

# Security
SECRET_KEY=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# Runtime
UVICORN_WORKERS=1

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Interview settings
INTERVIEW_QUESTION_COUNT=5
INTERVIEW_QUESTION_TIME_SECONDS=120
