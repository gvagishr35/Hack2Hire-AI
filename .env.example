# =============================================================================
# Hack2Hire — Docker environment variables
# Copy to .env:  cp .env.example .env
# =============================================================================

# Application
APP_NAME=Hack2Hire API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# API server (inside container)
HOST=0.0.0.0
PORT=8000
API_PORT=8000
UVICORN_WORKERS=1

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hack2hire
POSTGRES_PORT=5432

# Database URLs (use Docker service hostnames)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/hack2hire
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@postgres:5432/hack2hire

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# Security — change before production deployment
SECRET_KEY=dev-only-change-this-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
INTERVIEW_QUESTION_COUNT=5
INTERVIEW_QUESTION_TIME_SECONDS=120
INTERVIEW_EARLY_TERMINATION_AVG=25
INTERVIEW_EARLY_TERMINATION_MIN_ANSWERS=2
INTERVIEW_SINGLE_ANSWER_FAIL_THRESHOLD=15
